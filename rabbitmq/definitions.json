      "routing_key": "comment.created",
      "arguments": {}
    },
    {
      "source": "pulsepost_events",
      "vhost": "/",
      "destination": "notification-service-queue",
      "destination_type": "queue",
      "routing_key": "like.added",
      "arguments": {}
    },
    {
      "source": "pulsepost_events",
      "vhost": "/",
      "destination": "notification-service-queue",
